@{
    ViewData["Title"] = "Clint McMahon – Software Engineer & Architect";
    ViewData["Description"] = "Software engineer and architect in Minneapolis, designing and building systems for the legal industry. Specializing in .NET, Azure, and solving complex technical problems.";
}
@model IEnumerable<Post>

<section class="hero">
    <p class="hero-label">Hi, I'm Clint</p>
    <h1 class="hero-heading">I build things<br>for the Internet.</h1>
    <p class="hero-body">
        Software engineer and architect in Minneapolis. I design and build systems for the legal industry, specializing in .NET and Azure. I also write about software, espresso, and whatever side project has my attention.
    </p>
    <a class="btn-hero" href="/contact">Get in touch &rarr;</a>
</section>

<div class="home-cards">
    <a href="/portfolio" class="home-card featured">
        <h2>Work</h2>
        <p>Custom software for healthcare, legal, and government. Data platforms, legacy modernization, integrations that actually hold up in production.</p>
        <span class="card-cta">View portfolio &rarr;</span>
    </a>
    <a href="/projects" class="home-card">
        <h2>Projects</h2>
        <p>Side projects built to scratch my own itches: coffee maps, weather data tools, browser extensions, and a few things I haven't shipped yet.</p>
        <span class="card-cta">See all projects &rarr;</span>
    </a>
</div>

<section class="blog-list">
    <p class="blog-list-heading">Recent Posts</p>
    @foreach (var post in Model)
    {
        <a class="post-row" href="@Url.Action("Details", "Blog", new { slug = post.Slug })">
            <span class="post-date">@post.Date.ToString("MMM dd")</span>
            <span class="post-arrow">&rarr;</span>
            <span class="post-title">@post.Title</span>
        </a>
    }
    <a href="/blog" class="blog-see-all">All posts &rarr;</a>
</section>
