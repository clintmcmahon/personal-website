@model Website.Models.PhotoEntry
@{
    ViewData["Title"] = $"Edit: {Model.Title} — Admin";
    Layout = "_AdminLayout";

    var flatImages = Model.Rows.SelectMany(r => r).ToList();
    var tagsRaw = string.Join(", ", Model.Tags ?? new List<string>());
}

<div class="admin-toolbar">
    <h1>Edit Photo</h1>
    <div style="display:flex; gap:1rem; align-items:center;">
        @if (!Model.Draft)
        {
            <a href="/photos/@Model.Date.ToString("yyyy-MM-dd")" target="_blank" class="admin-link">View live →</a>
        }
        <a href="/admin/photos" class="admin-link">← All photos</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="admin-flash admin-flash--success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="admin-flash admin-flash--error">@TempData["Error"]</div>
}

<form method="post" action="/admin/photos/@Model.Id/edit" class="admin-form">
    @Html.AntiForgeryToken()

    <div class="admin-field">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" value="@Model.Title" class="admin-input" required autofocus />
    </div>

    <div class="admin-field-row">
        <div class="admin-field">
            <label for="slug">Slug <span class="admin-hint">(used for the URL)</span></label>
            <input type="text" id="slug" name="slug" value="@Model.Slug" class="admin-input admin-input--mono" />
        </div>
        <div class="admin-field">
            <label for="postDate">Date</label>
            <input type="date" id="postDate" name="postDate" value="@Model.Date.ToString("yyyy-MM-dd")" class="admin-input admin-input--mono" />
        </div>
        <div class="admin-field admin-field--narrow">
            <label for="draft">Draft</label>
            <input type="checkbox" id="draft" name="draft" value="true" @(Model.Draft ? "checked" : "") class="admin-checkbox" />
        </div>
    </div>

    <div class="admin-field">
        <label for="tags">Tags <span class="admin-hint">(comma-separated)</span></label>
        <input type="text" id="tags" name="tags" value="@tagsRaw" class="admin-input" placeholder="minneapolis, street" />
    </div>

    <div class="admin-field">
        <label for="content">Caption <span class="admin-hint">(HTML — shown below the photo)</span></label>
        <textarea id="content" name="content" class="admin-input" rows="4">@Model.Content</textarea>
    </div>

    <div class="admin-field">
        <label>
            <input type="checkbox" name="layoutRows" value="true" @(Model.FullRows ? "checked" : "") class="admin-checkbox" style="margin-right:0.375rem;" />
            Stack images in rows (full-width layout)
        </label>
    </div>

    @if (flatImages.Any())
    {
        <div class="admin-field" style="margin-top:1.5rem;">
            <label>Images <span class="admin-hint">(edit alt text — filenames are read-only)</span></label>
            <div style="display:flex; flex-direction:column; gap:0.75rem; margin-top:0.5rem;">
                @for (int i = 0; i < flatImages.Count; i++)
                {
                    var img = flatImages[i];
                    <div style="display:grid; grid-template-columns:72px 1fr; gap:0.75rem; align-items:center; padding:0.75rem; border:1px solid var(--border); border-radius:var(--radius);">
                        <img src="@img.Url" alt=""
                             style="width:72px; height:72px; object-fit:cover; border-radius:4px; display:block;" />
                        <div>
                            <div class="admin-input--mono" style="font-size:0.75rem; color:var(--text-muted); margin-bottom:0.375rem; word-break:break-all;">@img.Url</div>
                            <input type="text" name="altTexts" value="@img.Alt" class="admin-input"
                                   placeholder="Alt text — describe this image" />
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary">Save changes</button>
    </div>
</form>

<form method="post" action="/admin/photos/@Model.Id/publish" style="margin-top:0.5rem;">
    @Html.AntiForgeryToken()
    <button type="submit" class="admin-btn @(Model.Draft ? "admin-btn--publish" : "admin-btn--ghost")">
        @(Model.Draft ? "Publish" : "Unpublish")
    </button>
</form>
