@{
    ViewData["Title"] = "New Photo Post — Admin";
    Layout = "_AdminLayout";
}

<div class="admin-toolbar">
    <h1>New Photo Post</h1>
    <div style="display:flex; gap:1rem; align-items:center;">
        <a href="/admin/photos/migrate" class="admin-link">Import from filesystem →</a>
        <a href="/admin" class="admin-link">← Admin</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="admin-flash admin-flash--success">@TempData["Success"]</div>
}

@if (!ViewData.ModelState.IsValid)
{
    <div class="admin-flash admin-flash--error">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@error.ErrorMessage</div>
        }
    </div>
}

<form method="post" enctype="multipart/form-data" id="photoForm" class="admin-form">
    <div class="admin-form-field">
        <label class="admin-label">Title <span style="color:var(--error,#c0392b)">*</span></label>
        <input type="text" name="title" class="admin-input" required placeholder="e.g. US Bank Plaza — Downtown Minneapolis" />
    </div>

    <div class="admin-form-field">
        <label class="admin-label">Date <span class="admin-label-hint">(optional — defaults to today)</span></label>
        <input type="date" name="postDate" class="admin-input" />
    </div>

    <div class="admin-form-field">
        <label class="admin-label">Tags <span class="admin-label-hint">(comma-separated)</span></label>
        <input type="text" name="tags" class="admin-input" placeholder="minneapolis, street" />
    </div>

    <div class="admin-form-field">
        <label class="admin-label">Body <span class="admin-label-hint">(optional)</span></label>
        <textarea name="body" class="admin-input" rows="4" placeholder="Caption or description..."></textarea>
    </div>

    <div style="display:flex; gap:2rem; margin-bottom:1.25rem;">
        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
            <input type="checkbox" name="layoutRows" value="true" />
            <span>Stack images in rows</span>
        </label>
        <label style="display:flex; align-items:center; gap:0.5rem; cursor:pointer;">
            <input type="checkbox" name="draft" value="true" />
            <span>Save as draft</span>
        </label>
    </div>

    <div id="dropZone" style="border: 2px dashed var(--border); border-radius: var(--radius-lg, 8px); padding: 2.5rem 1rem; text-align:center; color:var(--text-muted); cursor:pointer; transition: border-color .15s, background .15s; user-select:none; margin-bottom: 1rem;">
        <div style="font-size:2rem; margin-bottom:.5rem;">&#128247;</div>
        <div style="font-weight:600;">Drop images here</div>
        <div style="font-size:0.875rem; margin-top:0.25rem;">or click to select — you can drop multiple at once</div>
    </div>
    <input type="file" id="filePickerInput" accept="image/*" multiple style="display:none" />

    <div id="imageSlots" style="margin-bottom:1rem;"></div>

    <div class="admin-form-actions">
        <button type="submit" class="admin-btn admin-btn--primary" id="submitBtn">Save Post</button>
    </div>
</form>

<script>
    var slotCount = 0;

    function createSlot(file) {
        slotCount++;
        var slot = document.createElement('div');
        slot.style.cssText = 'border:1px solid var(--border); border-radius:6px; padding:1rem; margin-bottom:0.75rem;';

        var header = document.createElement('div');
        header.style.cssText = 'display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;';
        header.innerHTML = '<span style="font-weight:600;">Image ' + slotCount + ' <span style="color:var(--text-muted); font-weight:400; font-size:0.875rem;">' + file.name + '</span></span>';

        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'admin-btn admin-btn--ghost';
        removeBtn.style.cssText = 'padding:0.2rem 0.6rem; font-size:0.8rem;';
        removeBtn.textContent = 'Remove';
        removeBtn.addEventListener('click', function () { slot.remove(); });
        header.appendChild(removeBtn);

        var preview = document.createElement('img');
        preview.src = URL.createObjectURL(file);
        preview.style.cssText = 'max-width:100%; max-height:220px; object-fit:contain; border-radius:4px; display:block; margin-bottom:0.5rem;';

        var fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.name = 'images';
        fileInput.accept = 'image/*';
        fileInput.style.display = 'none';

        var dt = new DataTransfer();
        dt.items.add(file);
        fileInput.files = dt.files;

        var altInput = document.createElement('input');
        altInput.type = 'text';
        altInput.name = 'altTexts';
        altInput.className = 'admin-input';
        altInput.required = true;
        altInput.placeholder = 'Alt text — describe this image';

        slot.appendChild(header);
        slot.appendChild(preview);
        slot.appendChild(altInput);
        slot.appendChild(fileInput);
        document.getElementById('imageSlots').appendChild(slot);
        altInput.focus();
    }

    function addFiles(files) {
        Array.from(files).forEach(function (f) {
            if (f.type.startsWith('image/')) createSlot(f);
        });
    }

    var dropZone = document.getElementById('dropZone');
    var filePicker = document.getElementById('filePickerInput');

    dropZone.addEventListener('click', function () { filePicker.click(); });
    filePicker.addEventListener('change', function () { addFiles(filePicker.files); filePicker.value = ''; });

    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropZone.style.borderColor = 'var(--accent)';
        dropZone.style.background = 'var(--bg-subtle, #f7f7f7)';
    });
    dropZone.addEventListener('dragleave', function () {
        dropZone.style.borderColor = 'var(--border)';
        dropZone.style.background = '';
    });
    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        dropZone.style.borderColor = 'var(--border)';
        dropZone.style.background = '';
        addFiles(e.dataTransfer.files);
    });

    document.getElementById('photoForm').addEventListener('submit', function () {
        var btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.textContent = 'Saving…';
    });
</script>
