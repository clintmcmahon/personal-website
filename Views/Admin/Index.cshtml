@{
    ViewData["Title"] = "Admin — Clint McMahon";
    Layout = "_AdminLayout";
}

<div style="max-width: 640px;">
    <div class="admin-toolbar" style="margin-bottom: 2.5rem;">
        <h1>Admin</h1>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem;">

        <a href="/admin/blog" style="display:block; padding: 1.75rem; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s;"
           onmouseover="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.06)'"
           onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
            <div style="font-size: 1.5rem; margin-bottom: 0.625rem;">✍️</div>
            <div style="font-weight: 600; color: var(--text); margin-bottom: 0.25rem;">Blog Posts</div>
            <div style="font-size: 0.875rem; color: var(--text-muted);">Write, edit, and publish posts</div>
        </a>

        <a href="/admin/blog/new" style="display:block; padding: 1.75rem; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s;"
           onmouseover="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.06)'"
           onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
            <div style="font-size: 1.5rem; margin-bottom: 0.625rem;">📝</div>
            <div style="font-weight: 600; color: var(--text); margin-bottom: 0.25rem;">New Post</div>
            <div style="font-size: 0.875rem; color: var(--text-muted);">Start writing something</div>
        </a>

        <a href="/admin/photos" style="display:block; padding: 1.75rem; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s;"
           onmouseover="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.06)'"
           onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
            <div style="font-size: 1.5rem; margin-bottom: 0.625rem;">📷</div>
            <div style="font-weight: 600; color: var(--text); margin-bottom: 0.25rem;">Photos</div>
            <div style="font-size: 0.875rem; color: var(--text-muted);">Manage photo posts</div>
        </a>

        <a href="/admin/photos/new" style="display:block; padding: 1.75rem; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s;"
           onmouseover="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.06)'"
           onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
            <div style="font-size: 1.5rem; margin-bottom: 0.625rem;">🖼️</div>
            <div style="font-weight: 600; color: var(--text); margin-bottom: 0.25rem;">New Photo Post</div>
            <div style="font-size: 0.875rem; color: var(--text-muted);">Upload photos to the photoblog</div>
        </a>

        <a href="/" target="_blank" style="display:block; padding: 1.75rem; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s;"
           onmouseover="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.06)'"
           onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
            <div style="font-size: 1.5rem; margin-bottom: 0.625rem;">🌐</div>
            <div style="font-weight: 600; color: var(--text); margin-bottom: 0.25rem;">View Site</div>
            <div style="font-size: 0.875rem; color: var(--text-muted);">Open the public site</div>
        </a>

        <a href="/admin/backup" style="display:block; padding: 1.75rem; background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-lg); text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s;"
           onmouseover="this.style.borderColor='var(--accent)'; this.style.boxShadow='0 4px 16px rgba(0,0,0,0.06)'"
           onmouseout="this.style.borderColor='var(--border)'; this.style.boxShadow='none'">
            <div style="font-size: 1.5rem; margin-bottom: 0.625rem;">💾</div>
            <div style="font-weight: 600; color: var(--text); margin-bottom: 0.25rem;">Backup</div>
            <div style="font-size: 0.875rem; color: var(--text-muted);">Download app files and databases</div>
        </a>

    </div>
</div>
