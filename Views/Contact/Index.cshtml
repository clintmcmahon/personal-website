@{
    ViewData["Title"] = "Contact | Clint McMahon — Technology Consultant";
    ViewData["Description"] = "Get in touch about a stalled project, a new build, or a technology initiative that needs rescuing. I read and respond to every message myself.";
}

<section class="contact py-5">
  <div class="container" style="max-width:800px">
    <h1 class="display-4 fw-bold text-center mb-3">Let's Talk</h1>
    <p class="lead text-center mb-4">Stalled project, new idea, or a system that's held together with hope — tell me what's going on and I'll get back to you personally, usually within a day or two.</p>

    <div class="d-flex flex-wrap justify-content-center gap-2 mb-5">
      <a href="/services" class="btn btn-outline-secondary btn-sm">See what I do</a>
      <a href="/services/rescue-recovery" class="btn btn-outline-secondary btn-sm">The rescue audit</a>
      <a href="/portfolio" class="btn btn-outline-secondary btn-sm">My work</a>
    </div>

    <div class="row g-4">
    <div class="col">
    @Html.Partial("_Contact")
</div>
    </div>
  </div>
</section>
