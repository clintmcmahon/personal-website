@model PhotoViewModel

@{
    Layout = null;
    ViewData["Title"] = Model.CurrentPhoto.Title + " — Clint McMahon";
    var canonicalUrl = $"https://photos.clintmcmahon.com/{Model.CurrentPhoto.Date:yyyy-MM-dd}";
    ViewData["PhotoDate"] = Model.CurrentPhoto.Date.ToString("yyyy-MM-dd");

    var isSubdomain = Context.Request.Host.Host.StartsWith("photos.", StringComparison.OrdinalIgnoreCase);
    var photoBase  = isSubdomain ? "/"         : "/photos/";  // base for /{date} links
    var homeHref   = isSubdomain ? "/"         : "/photos";   // site-name link
    var aboutHref  = isSubdomain ? "/about"    : "/photos/about";
    var rssHref    = isSubdomain ? "/rss"      : "/photos/rss";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="@Model.CurrentPhoto.Title" />
    <meta property="og:title" content="@Model.CurrentPhoto.Title" />
    <meta property="og:image" content="@Model.CurrentPhoto.ImageUrl" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:type" content="article" />
    <link rel="canonical" href="@canonicalUrl" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/css/classic-photoblog.css?v=3" />
</head>
<body>
    <header class="pb-header">
        <a href="@homeHref" class="pb-site-name">Clint McMahon</a>
        <span class="pb-header-byline">photographs from the life of <a href="https://clintmcmahon.com" class="pb-header-byline-link">clintmcmahon.com</a></span>
        <span class="pb-header-date">@Model.CurrentPhoto.Date.ToString("MMMM d, yyyy")</span>
    </header>

    <main class="pb-main">
        <nav class="pb-nav pb-nav--top" aria-label="Photo navigation">
            @if (Model.PreviousPhoto != null)
            {
                <a href="@photoBase@Model.PreviousPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-prev"
                   title="@Model.PreviousPhoto.Title">&#8592; prev</a>
            }
            else
            {
                <span></span>
            }
            @if (Model.NextPhoto != null)
            {
                <a href="@photoBase@Model.NextPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-next"
                   title="@Model.NextPhoto.Title">next &#8594;</a>
            }
        </nav>

        <div class="pb-rows">
            @foreach (var row in Model.CurrentPhoto.Rows)
            {
                <div class="pb-row">
                    @foreach (var img in row)
                    {
                        var altText = string.IsNullOrEmpty(img.Alt) ? Model.CurrentPhoto.Title : img.Alt;
                        <img src="@img.Url"
                             class="pb-image"
                             alt="@altText"
                             title="@altText" />
                    }
                </div>
            }
        </div>

        <div class="pb-meta">
            <div class="pb-caption-area">
                @if (!string.IsNullOrWhiteSpace(Model.CurrentPhoto.Title))
                {
                    <p class="pb-title">@Model.CurrentPhoto.Title</p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.CurrentPhoto.Content))
                {
                    <div class="pb-caption">@Html.Raw(Model.CurrentPhoto.Content)</div>
                }
            </div>
        </div>

        <nav class="pb-nav pb-nav--top" aria-label="Photo navigation">
            @if (Model.PreviousPhoto != null)
            {
                <a href="@photoBase@Model.PreviousPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-prev"
                   title="@Model.PreviousPhoto.Title">&#8592; prev</a>
            }
            else
            {
                <span></span>
            }
            @if (Model.NextPhoto != null)
            {
                <a href="@photoBase@Model.NextPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-next"
                   title="@Model.NextPhoto.Title">next &#8594;</a>
            }
        </nav>

        <div class="pb-comments" id="comments">
            @await Html.PartialAsync("_PhotoComments", Model.Comments)
        </div>

        <footer class="pb-footer">
            <nav class="pb-footer-nav">
                <a href="@aboutHref" class="pb-footer-link">About</a>
                <a href="@rssHref" class="pb-footer-link">RSS</a>
                <a href="https://clintmcmahon.com" class="pb-footer-link">clintmcmahon.com</a>
            </nav>
        </footer>
    </main>

    <div class="pb-keys" aria-hidden="true">&#8592; &#8594;</div>

    <script>
        document.querySelectorAll('.pb-image').forEach(function (img) {
            function show() { img.classList.add('is-loaded'); }
            img.complete ? show() : img.addEventListener('load', show);
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'ArrowLeft') {
                var a = document.querySelector('.pb-nav-prev');
                if (a) window.location.href = a.href;
            } else if (e.key === 'ArrowRight') {
                var a = document.querySelector('.pb-nav-next');
                if (a) window.location.href = a.href;
            }
        });

        var _tx = 0;
        document.addEventListener('touchstart', function (e) {
            _tx = e.touches[0].clientX;
        }, { passive: true });
        document.addEventListener('touchend', function (e) {
            var dx = e.changedTouches[0].clientX - _tx;
            if (Math.abs(dx) < 60) return;
            var sel = dx > 0 ? '.pb-nav-prev' : '.pb-nav-next';
            var a = document.querySelector(sel);
            if (a) window.location.href = a.href;
        }, { passive: true });
    </script>
</body>
</html>
