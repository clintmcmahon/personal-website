@model PhotoViewModel

@{
    Layout = null;
    var photo = Model.CurrentPhoto;
    var canonicalUrl = $"https://photos.clintmcmahon.com/{photo.Date:yyyy-MM-dd}";
    ViewData["PhotoDate"] = photo.Date.ToString("yyyy-MM-dd");

    var isSubdomain = Context.Request.Host.Host.StartsWith("photos.", StringComparison.OrdinalIgnoreCase);
    var photoBase   = isSubdomain ? "/"         : "/photos/";
    var homeHref    = isSubdomain ? "/"         : "/photos";
    var archiveHref = isSubdomain ? "/archive"  : "/photos/archive";
    var aboutHref   = isSubdomain ? "/about"    : "/photos/about";
    var rssHref     = isSubdomain ? "/rss"      : "/photos/rss";
    var tagBase     = isSubdomain ? "/tag/"     : "/photos/tag/";

    // Absolute image URL for OG / Twitter / JSON-LD
    var absoluteImage = photo.ImageUrl.StartsWith("http")
        ? photo.ImageUrl
        : $"https://photos.clintmcmahon.com{photo.ImageUrl}";

    // Page title: use caption body first, then tags, then date
    var hasTitle  = !string.IsNullOrWhiteSpace(photo.Title);
    var pageTitle = hasTitle
        ? $"{photo.Title} — Clint McMahon Photos"
        : $"Photo {photo.Date:MMMM d, yyyy} — Clint McMahon Photos";
    ViewData["Title"] = pageTitle;

    // Meta description: caption > tag+date sentence > date-only fallback
    var rawDesc = !string.IsNullOrWhiteSpace(photo.Content)
        ? System.Text.RegularExpressions.Regex.Replace(photo.Content, "<[^>]+>", "").Trim()
        : "";
    var metaDescription = rawDesc.Length > 0
        ? (rawDesc.Length > 160 ? rawDesc[..157] + "…" : rawDesc)
        : photo.Tags.Any()
            ? $"Photo taken {photo.Date:MMMM d, yyyy} in {photo.Tags.First()} by Clint McMahon."
            : $"A photo by Clint McMahon from {photo.Date:MMMM d, yyyy}.";

    // JSON-LD author block (reused below)
    var jsonTitle = System.Text.Json.JsonEncodedText.Encode(hasTitle ? photo.Title : photo.Date.ToString("MMMM d, yyyy"));
    var jsonDesc  = System.Text.Json.JsonEncodedText.Encode(metaDescription);
    var jsonDate  = photo.Date.ToString("yyyy-MM-dd");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="@metaDescription" />
    <meta name="author" content="Clint McMahon" />

    <!-- Open Graph -->
    <meta property="og:title" content="@pageTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:image" content="@absoluteImage" />
    <meta property="og:image:alt" content="@(hasTitle ? photo.Title : $"Photo from {photo.Date:MMMM d, yyyy}")" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Clint McMahon Photos" />
    <meta property="article:published_time" content="@jsonDate" />
    <meta property="article:author" content="https://clintmcmahon.com" />

    <!-- Twitter / X card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@@cwmcmhn" />
    <meta name="twitter:title" content="@pageTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image" content="@absoluteImage" />
    <meta name="twitter:image:alt" content="@(hasTitle ? photo.Title : $"Photo from {photo.Date:MMMM d, yyyy}")" />

    <link rel="canonical" href="@canonicalUrl" />
    <link rel="alternate" type="application/rss+xml" title="Clint McMahon Photos" href="https://photos.clintmcmahon.com/rss" />
    @if (Model.PreviousPhoto != null)
    {
        <link rel="prev" href="https://photos.clintmcmahon.com/@Model.PreviousPhoto.Date.ToString("yyyy-MM-dd")" />
    }
    @if (Model.NextPhoto != null)
    {
        <link rel="next" href="https://photos.clintmcmahon.com/@Model.NextPhoto.Date.ToString("yyyy-MM-dd")" />
    }
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/css/classic-photoblog.css?v=6" />
    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-hjNpxaHKa9c0U9E_rhYo2.js"></script>
    <script>
        window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
        plausible.init()
    </script>
    <link rel="webmention" href="https://webmention.io/photos.clintmcmahon.com/webmention" />
    <link rel="me" href="https://github.com/clintmcmahon" />
    <link rel="me" href="https://indieweb.social/@@clint" />

    <!-- JSON-LD structured data -->
    <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "ImageObject",
      "contentUrl": "@absoluteImage",
      "url": "@canonicalUrl",
      "name": "@jsonTitle",
      "description": "@jsonDesc",
      "datePublished": "@jsonDate",
      "author": {
        "@@type": "Person",
        "name": "Clint McMahon",
        "url": "https://clintmcmahon.com"
      },
      "copyrightHolder": {
        "@@type": "Person",
        "name": "Clint McMahon"
      }@if (photo.Tags.Any()) {<text>,
      "keywords": "@string.Join(", ", photo.Tags)"</text>}
    }
    </script>
</head>
<body>
    @await Html.PartialAsync("_HCard")
    <header class="pb-header">
        <a href="@homeHref" class="pb-site-name">Clint McMahon</a>
        <span class="pb-header-byline">photographs from the life of <a href="https://clintmcmahon.com" class="pb-header-byline-link">clintmcmahon.com</a></span>
    </header>

    <main class="pb-main h-entry">
        <a class="u-url" href="@canonicalUrl" hidden></a>
        <a class="u-author" href="https://clintmcmahon.com/" hidden></a>
        <nav class="pb-nav pb-nav--top" aria-label="Photo navigation">
            @if (Model.PreviousPhoto != null)
            {
                <a href="@photoBase@Model.PreviousPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-prev"
                   title="@Model.PreviousPhoto.Title">&#8592; prev</a>
            }
            else
            {
                <span></span>
            }
            <a href="@archiveHref" class="pb-nav-archive">archive</a>
            @if (Model.NextPhoto != null)
            {
                <a href="@photoBase@Model.NextPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-next"
                   title="@Model.NextPhoto.Title">next &#8594;</a>
            }
        </nav>

        <time class="pb-date-above dt-published" datetime="@Model.CurrentPhoto.Date.ToString("yyyy-MM-dd")">@Model.CurrentPhoto.Date.ToString("MMMM d, yyyy")</time>

        <div class="pb-rows">
            @if (photo.FullRows)
            {
                foreach (var row in photo.Rows)
                {
                    <div class="pb-row">
                        @foreach (var img in row)
                        {
                            var altText = string.IsNullOrEmpty(img.Alt) ? photo.Title : img.Alt;
                            <img src="@img.Url"
                                 class="pb-image u-photo"
                                 alt="@altText"
                                 title="@altText"
                                 data-caption="@img.Alt" />
                        }
                    </div>
                }
            }
            else
            {
                var allRows = photo.Rows.ToList();
                var firstRow = allRows.FirstOrDefault();
                var remainingImages = allRows.Skip(1).SelectMany(r => r).ToList();
                if (firstRow != null)
                {
                    <div class="pb-row">
                        @foreach (var img in firstRow)
                        {
                            var altText = string.IsNullOrEmpty(img.Alt) ? photo.Title : img.Alt;
                            <img src="@img.Url"
                                 class="pb-image u-photo"
                                 alt="@altText"
                                 title="@altText"
                                 data-caption="@img.Alt" />
                        }
                    </div>
                }
                if (remainingImages.Any())
                {
                    <div class="pb-masonry">
                        @foreach (var img in remainingImages)
                        {
                            var altText = string.IsNullOrEmpty(img.Alt) ? photo.Title : img.Alt;
                            <img src="@img.Url"
                                 class="pb-masonry-img u-photo"
                                 alt="@altText"
                                 title="@altText"
                                 data-caption="@img.Alt" />
                        }
                    </div>
                }
            }
        </div>

        <div class="pb-meta">
            <div class="pb-caption-area">
                @if (!string.IsNullOrWhiteSpace(photo.Title))
                {
                    <p class="pb-title p-name">@photo.Title</p>
                }
                @if (!string.IsNullOrWhiteSpace(photo.Content))
                {
                    <div class="pb-caption e-content">@Html.Raw(photo.Content)</div>
                }
                @if (photo.Tags.Any())
                {
                    <div class="pb-detail-tags">
                        @foreach (var tag in photo.Tags)
                        {
                            <a href="@tagBase@Uri.EscapeDataString(tag)" class="pb-tag-pill p-category">@tag</a>
                        }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(photo.SyndicationUrl))
                {
                    <a class="u-syndication pb-tag-pill" href="@photo.SyndicationUrl" target="_blank" rel="noopener noreferrer">View on Mastodon</a>
                }
            </div>
        </div>

        <nav class="pb-nav pb-nav--top" aria-label="Photo navigation">
            @if (Model.PreviousPhoto != null)
            {
                <a href="@photoBase@Model.PreviousPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-prev"
                   title="@Model.PreviousPhoto.Title">&#8592; prev</a>
            }
            else
            {
                <span></span>
            }
            @if (Model.NextPhoto != null)
            {
                <a href="@photoBase@Model.NextPhoto.Date.ToString("yyyy-MM-dd")"
                   class="pb-nav-next"
                   title="@Model.NextPhoto.Title">next &#8594;</a>
            }
        </nav>

        <div class="pb-comments" id="comments">
            @await Html.PartialAsync("_PhotoComments", Model.Comments)
        </div>

        <div style="width:100%;max-width:min(92vw,1000px)">
            @await Html.PartialAsync("_Webmentions", canonicalUrl)
        </div>

        <footer class="pb-footer">
            <nav class="pb-footer-nav">
                <a href="@archiveHref" class="pb-footer-link">Archive</a>
                <a href="@aboutHref" class="pb-footer-link">About</a>
                <a href="@rssHref" class="pb-footer-link">RSS</a>
                <a href="https://www.instagram.com/cwmcmhn/" class="pb-footer-link" target="_blank">Instagram</a>
                <a href="https://clintmcmahon.com" class="pb-footer-link">clintmcmahon.com</a>
            </nav>
        </footer>
    </main>

    <div class="pb-keys" aria-hidden="true">&#8592; &#8594;</div>

    <div class="pb-lightbox" id="pbLightbox" aria-hidden="true">
        <button type="button" class="pb-lightbox-close" aria-label="Close">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
        </button>
        <button type="button" class="pb-lightbox-prev" aria-label="Previous image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 6l-6 6 6 6"/></svg>
        </button>
        <button type="button" class="pb-lightbox-next" aria-label="Next image">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 6l6 6-6 6"/></svg>
        </button>
        <div class="pb-lightbox-stage">
            <img class="pb-lightbox-img" src="" alt="" />
        </div>
        <div class="pb-lightbox-info">
            <p class="pb-lightbox-caption"></p>
            <span class="pb-lightbox-counter"></span>
        </div>
    </div>

    <script>
    (function () {
        var images = Array.prototype.slice.call(document.querySelectorAll('.pb-image, .pb-masonry-img'));

        images.forEach(function (img) {
            function show() { img.classList.add('is-loaded'); }
            img.complete ? show() : img.addEventListener('load', show);
        });

        // ---- Lightbox --------------------------------------------
        var lightbox  = document.getElementById('pbLightbox');
        var stage     = lightbox.querySelector('.pb-lightbox-stage');
        var stageImg  = lightbox.querySelector('.pb-lightbox-img');
        var captionEl = lightbox.querySelector('.pb-lightbox-caption');
        var counterEl = lightbox.querySelector('.pb-lightbox-counter');
        var closeBtn  = lightbox.querySelector('.pb-lightbox-close');
        var prevBtn   = lightbox.querySelector('.pb-lightbox-prev');
        var nextBtn   = lightbox.querySelector('.pb-lightbox-next');

        var items = images.map(function (img) {
            return { src: img.src, alt: img.alt || '', caption: img.getAttribute('data-caption') || '' };
        });

        var index = 0;
        var isOpen = false;
        var lastFocused = null;

        if (items.length < 2) lightbox.classList.add('pb-lightbox--single');

        function preload(i) {
            if (i < 0 || i >= items.length) return;
            var im = new Image();
            im.src = items[i].src;
        }

        function render() {
            var item = items[index];
            stageImg.classList.remove('is-visible');
            requestAnimationFrame(function () {
                stageImg.src = item.src;
                stageImg.alt = item.alt;
                var show = function () { stageImg.classList.add('is-visible'); };
                if (stageImg.complete && stageImg.naturalWidth) show();
                else stageImg.addEventListener('load', show, { once: true });
            });
            captionEl.textContent = item.caption;
            captionEl.style.display = item.caption ? '' : 'none';
            counterEl.textContent = items.length > 1 ? (index + 1) + ' / ' + items.length : '';
            preload(index + 1);
            preload(index - 1);
        }

        function openLightbox(i) {
            index = i;
            isOpen = true;
            lastFocused = document.activeElement;
            document.body.classList.add('pb-lightbox-open');
            lightbox.classList.add('is-open');
            lightbox.setAttribute('aria-hidden', 'false');
            render();
            closeBtn.focus();
        }

        function closeLightbox() {
            isOpen = false;
            document.body.classList.remove('pb-lightbox-open');
            lightbox.classList.remove('is-open');
            lightbox.setAttribute('aria-hidden', 'true');
            stageImg.classList.remove('is-visible');
            if (lastFocused && lastFocused.focus) lastFocused.focus();
        }

        function nextImage() {
            if (items.length < 2) return;
            index = (index + 1) % items.length;
            render();
        }

        function prevImage() {
            if (items.length < 2) return;
            index = (index - 1 + items.length) % items.length;
            render();
        }

        images.forEach(function (img, i) {
            img.setAttribute('tabindex', '0');
            img.setAttribute('role', 'button');
            img.addEventListener('click', function () { openLightbox(i); });
            img.addEventListener('keydown', function (e) {
                if (e.key === 'Enter' || e.key === ' ') {
                    e.preventDefault();
                    openLightbox(i);
                }
            });
        });

        closeBtn.addEventListener('click', closeLightbox);
        nextBtn.addEventListener('click', nextImage);
        prevBtn.addEventListener('click', prevImage);

        stage.addEventListener('click', function (e) {
            if (e.target === stage) closeLightbox();
        });

        var lbTouchX = 0, lbTouchY = 0;
        lightbox.addEventListener('touchstart', function (e) {
            lbTouchX = e.touches[0].clientX;
            lbTouchY = e.touches[0].clientY;
        }, { passive: true });
        lightbox.addEventListener('touchend', function (e) {
            var dx = e.changedTouches[0].clientX - lbTouchX;
            var dy = e.changedTouches[0].clientY - lbTouchY;
            if (Math.abs(dx) < 40 || Math.abs(dx) < Math.abs(dy)) return;
            if (dx > 0) prevImage(); else nextImage();
        }, { passive: true });

        // ---- Keyboard / swipe (page-level, yields to an open lightbox) ----
        document.addEventListener('keydown', function (e) {
            if (isOpen) {
                if (e.key === 'Escape') closeLightbox();
                else if (e.key === 'ArrowRight') nextImage();
                else if (e.key === 'ArrowLeft') prevImage();
                return;
            }
            if (e.key === 'ArrowLeft') {
                var a = document.querySelector('.pb-nav-prev');
                if (a) window.location.href = a.href;
            } else if (e.key === 'ArrowRight') {
                var b = document.querySelector('.pb-nav-next');
                if (b) window.location.href = b.href;
            }
        });

        var _tx = 0;
        document.addEventListener('touchstart', function (e) {
            if (isOpen) return;
            _tx = e.touches[0].clientX;
        }, { passive: true });
        document.addEventListener('touchend', function (e) {
            if (isOpen) return;
            var dx = e.changedTouches[0].clientX - _tx;
            if (Math.abs(dx) < 60) return;
            var sel = dx > 0 ? '.pb-nav-prev' : '.pb-nav-next';
            var a = document.querySelector(sel);
            if (a) window.location.href = a.href;
        }, { passive: true });
    })();
    </script>
</body>
</html>
