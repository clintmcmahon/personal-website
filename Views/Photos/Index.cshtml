@model Website.Models.PhotoIndexViewModel
@using System.Web

@{
    Layout = null;
    ViewData["Title"] = "Archive — Clint McMahon Photos";
    var canonicalUrl = "https://photos.clintmcmahon.com/archive";

    var isSubdomain = Context.Request.Host.Host.StartsWith("photos.", StringComparison.OrdinalIgnoreCase);
    var photoBase  = isSubdomain ? "/"         : "/photos/";
    var homeHref   = isSubdomain ? "/"         : "/photos";
    var aboutHref  = isSubdomain ? "/about"    : "/photos/about";
    var rssHref    = isSubdomain ? "/rss"      : "/photos/rss";
    var tagBase    = isSubdomain ? "/tag/"     : "/photos/tag/";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Photographs from the life of Clint McMahon — @Model.TotalCount photos spanning Minneapolis and beyond." />
    <meta property="og:title" content="Photos — Clint McMahon" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:type" content="website" />
    <link rel="canonical" href="@canonicalUrl" />
    <link rel="webmention" href="https://webmention.io/photos.clintmcmahon.com/webmention" />
    <link rel="me" href="https://github.com/clintmcmahon" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="/css/classic-photoblog.css?v=5" />
    <script defer data-domain="clintmcmahon.com" src="https://plausible.io/js/script.js"></script>
</head>
<body>

<header class="pb-header">
    <a href="@homeHref" class="pb-site-name">Clint McMahon</a>
    <span class="pb-header-byline">photographs from the life of <a href="https://clintmcmahon.com" class="pb-header-byline-link">clintmcmahon.com</a></span>
</header>

<nav class="pb-archive-nav" aria-label="Archive navigation">
    <div class="pb-year-nav" role="tablist">
        <span class="pb-year-nav-total">@Model.TotalCount photos</span>
        @foreach (var year in Model.Years)
        {
            <a href="#year-@year" class="pb-year-link" role="tab">
                @year
                <span class="pb-year-count">@Model.PhotosByYear[year].Count</span>
            </a>
        }
    </div>
    @if (Model.TopTags.Any())
    {
        <div class="pb-tag-strip" aria-label="Filter by tag">
            @foreach (var (tag, count) in Model.TopTags)
            {
                <a href="@tagBase@Uri.EscapeDataString(tag)" class="pb-tag-pill @(Model.ActiveTag == tag ? "is-active" : "")">
                    @tag
                    <span class="pb-tag-pill-count">@count</span>
                </a>
            }
        </div>
    }
</nav>

<main class="pb-archive-main">
    @foreach (var year in Model.Years)
    {
        <section id="year-@year" class="pb-year-section">
            <h2 class="pb-year-heading">
                @year
                <span class="pb-year-total">— @Model.PhotosByYear[year].Count photo@(Model.PhotosByYear[year].Count == 1 ? "" : "s")</span>
            </h2>
            <div class="pb-grid">
                @foreach (var photo in Model.PhotosByYear[year])
                {
                    <a href="@photoBase@photo.Date.ToString("yyyy-MM-dd")"
                       class="pb-grid-item"
                       data-src="@photo.ImageUrl"
                       aria-label="@photo.Date.ToString("MMMM d, yyyy")">
                        <img class="pb-grid-img" alt="@photo.Title" />
                        <div class="pb-grid-overlay" aria-hidden="true">
                            <div class="pb-grid-overlay-inner">
                                <time class="pb-grid-date" datetime="@photo.Date.ToString("yyyy-MM-dd")">
                                    @photo.Date.ToString("MMM d, yyyy")
                                </time>
                                @if (photo.Tags.Any())
                                {
                                    <span class="pb-grid-tag">@photo.Tags.First()</span>
                                }
                            </div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }
</main>

<footer class="pb-footer">
    <nav class="pb-footer-nav">
        <a href="@aboutHref" class="pb-footer-link">About</a>
        <a href="@rssHref" class="pb-footer-link">RSS</a>
        <a href="https://www.instagram.com/cwmcmhn/" class="pb-footer-link" target="_blank">Instagram</a>
        <a href="https://clintmcmahon.com" class="pb-footer-link">clintmcmahon.com</a>
    </nav>
</footer>

<script>
(function () {
    // Lazy-load images via IntersectionObserver
    const observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (!entry.isIntersecting) return;
            var item = entry.target;
            var img = item.querySelector('.pb-grid-img');
            if (img && !img.src) {
                img.src = item.dataset.src;
                img.addEventListener('load', function () { img.classList.add('is-loaded'); });
                img.addEventListener('error', function () { item.classList.add('pb-grid-item--error'); });
            }
            observer.unobserve(item);
        });
    }, { rootMargin: '400px 0px' });

    document.querySelectorAll('.pb-grid-item[data-src]').forEach(function (el) {
        observer.observe(el);
    });

    // Highlight active year in nav as user scrolls
    var yearLinks = Array.from(document.querySelectorAll('.pb-year-link'));
    var sections = Array.from(document.querySelectorAll('.pb-year-section'));

    var sectionObserver = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
            if (entry.isIntersecting) {
                var id = entry.target.id;
                yearLinks.forEach(function (link) {
                    link.classList.toggle('is-active', link.getAttribute('href') === '#' + id);
                });
            }
        });
    }, { rootMargin: '-40% 0px -55% 0px' });

    sections.forEach(function (s) { sectionObserver.observe(s); });

    // Smooth scroll for year nav links
    yearLinks.forEach(function (link) {
        link.addEventListener('click', function (e) {
            e.preventDefault();
            var target = document.querySelector(link.getAttribute('href'));
            if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
    });
})();
</script>

</body>
</html>
