@model List<Website.Models.PhotoEntry>

@{
    ViewData["Title"] = "Photos - Clint McMahon";
    ViewData["Description"] = "Photographs from the life of Clint McMahon.";
}

<div class="photo-feed">

    @if (!Model.Any())
    {
        <p class="photo-feed-empty">No photos yet. Check back soon.</p>
    }
    else
    {
        @for (int i = 0; i < Model.Count; i++)
        {
            var photo = Model[i];
            <article class="photo-entry">
                <a href="/photos/@photo.Date.ToString("yyyy-MM-dd")" class="photo-entry-link">
                    <img src="@photo.ImageUrl"
                         alt="@photo.Title"
                         class="photo-entry-img"
                         loading="@(i < 3 ? "eager" : "lazy")" />
                </a>
                <div class="photo-entry-meta">
                    <time class="photo-entry-date" datetime="@photo.Date.ToString("yyyy-MM-dd")">
                        @photo.Date.ToString("MMMM d, yyyy")
                    </time>
                    @if (!string.IsNullOrWhiteSpace(photo.Title))
                    {
                        <a href="/photos/@photo.Date.ToString("yyyy-MM-dd")" class="photo-entry-title">@photo.Title</a>
                    }
                </div>
            </article>

            @if (i < Model.Count - 1)
            {
                <div class="photo-separator" aria-hidden="true">
                    <span class="photo-separator-line"></span>
                    <span class="photo-separator-dot"></span>
                    <span class="photo-separator-line"></span>
                </div>
            }
        }
    }

</div>

@section Scripts {
<style>
    /* Pull out of Bootstrap's container padding and center at 1000px */
    .photo-feed {
        max-width: 1000px;
        margin: 2rem auto 4rem;
        padding: 0;
    }

    .photo-feed-empty {
        font-size: 0.82rem;
        color: #bbb;
        text-align: center;
        padding: 4rem 0;
    }

    /* Each photo post */
    .photo-entry {
        display: flex;
        flex-direction: column;
    }

    .photo-entry-link {
        display: block;
        line-height: 0; /* removes gap below img */
    }

    .photo-entry-img {
        width: 100%;
        height: auto;
        display: block;
        transition: opacity 0.2s ease;
    }

    .photo-entry-link:hover .photo-entry-img {
        opacity: 0.93;
    }

    /* Date + title row */
    .photo-entry-meta {
        display: flex;
        align-items: baseline;
        gap: 1.25rem;
        margin-top: 0.75rem;
    }

    .photo-entry-date {
        font-size: 0.69rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #bbb;
        white-space: nowrap;
        font-variant-numeric: tabular-nums;
    }

    .photo-entry-title {
        font-size: 0.82rem;
        font-weight: 500;
        color: #111;
        text-decoration: none;
        transition: color 0.15s;
    }

    .photo-entry-title:hover {
        color: #555;
    }

    /* Separator */
    .photo-separator {
        display: flex;
        align-items: center;
        gap: 0;
        margin: 3rem 0;
    }

    .photo-separator-line {
        flex: 1;
        height: 1px;
        background: #e8e8e8;
    }

    .photo-separator-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #d0d0d0;
        margin: 0 0.9rem;
        flex-shrink: 0;
    }

    @@media (max-width: 1040px) {
        .photo-feed {
            margin: 1.5rem 1.25rem 3rem;
        }
    }
</style>
}
