@model IEnumerable<Website.Models.PhotoComment>
@{
    var photoDate = ViewData["PhotoDate"] as string;
}

<h2 class="pb-comments-heading">Comments</h2>

@if (Model.Any())
{
    <ul class="pb-comment-list">
        @foreach (var comment in Model)
        {
            <li class="pb-comment-item">
                <div class="pb-comment-meta">
                    <span class="pb-comment-author">@comment.Name</span>
                    <span class="pb-comment-time">@comment.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</span>
                </div>
                <div class="pb-comment-body">@comment.Content</div>
            </li>
        }
    </ul>
}
else
{
    <p class="pb-no-comments">No comments yet.</p>
}

<form asp-controller="PhotoComments" asp-action="Post" method="post" class="pb-form">
    <input type="hidden" name="photoDate" value="@photoDate" />
    <input type="text" name="name" class="pb-input" placeholder="Name" required />
    <textarea name="content" class="pb-textarea" placeholder="Leave a comment" required></textarea>
    <button type="submit" class="pb-submit">Post</button>
</form>
