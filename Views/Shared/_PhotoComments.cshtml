@model IEnumerable<Website.Models.PhotoComment>
@{
    var photoDate = ViewData["PhotoDate"] as string;
}
<div class="photo-comments">
    <h3>Comments</h3>
    @if (!Model.Any())
    {
        <p>No comments yet. Be the first to comment!</p>
    }
    else
    {
        <ul>
        @foreach (var comment in Model)
        {
            <li>
                <strong>@comment.Name</strong> <span class="text-muted">(@comment.CreatedAt.ToLocalTime().ToString("g"))</span><br />
                @comment.Content
            </li>
        }
        </ul>
    }
    <form asp-controller="PhotoComments" asp-action="Post" method="post" class="mt-3">
        <input type="hidden" name="photoDate" value="@photoDate" />
        <div class="mb-2">
            <input type="text" name="name" class="form-control" placeholder="Your name" required />
        </div>
        <div class="mb-2">
            <textarea name="content" class="form-control" placeholder="Your comment" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Post Comment</button>
    </form>
</div>
